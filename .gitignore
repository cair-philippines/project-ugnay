# Pipeline outputs (large data files; all stored on GCS and regenerated by scripts)
output/

# Credentials — must never be committed
keys
.env
.env.*
*.pem
*service-account*.json

# Node (path-agnostic, so a node_modules/dist anywhere is caught, not just platform/frontend/)
node_modules/
dist/

# Docker build data staging (created by prepare_deploy.sh)
platform/data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Firebase deploy cache
.firebase/

# Transient artifacts (logs, temp files, editor swap/backup) — anything whose
# lifespan is a single task and which is never meant to be committed
*.log
*.tmp
*.bak
*.orig
*.swp
*~
